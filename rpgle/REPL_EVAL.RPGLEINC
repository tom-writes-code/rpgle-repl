**FREE

/If Defined(REPL_EVAL)
/Eof
/Endif
/Define REPL_EVAL

/include repl_pseu
/include repl_vars

/// @file REPL_EVAL
/// @brief Statement evaluator - identifies statement types and generates evaluation code.
/// @author Tom Sharp

/// Trigger type: conditional (if, else, elseif, when, other, on-error).
dcl-c c_conditionalStatement 'CON';
/// Trigger type: value assignment (a = b).
dcl-c c_setValueStatement 'VAL';
/// Trigger type: loop (dow, dou, for).
dcl-c c_loopStatement 'LOP';
/// Trigger type: embedded SQL (exec sql).
dcl-c c_sqlStatement 'SQL';
/// Trigger type: replPrint() call.
dcl-c c_replPrintStatement 'PRT';
/// Trigger type: replEquals() assertion call.
dcl-c c_replEqualsStatement 'EQL';

dcl-s t_triggerType char(3) template;

/// Insert evaluation code for a line of pseudo code.
///
/// Given the line number and metadata describing the statement, generates
/// and inserts the appropriate helper call into the generated source. For
/// conditionals, loops, SQL, and unknown-type assignments the built-in
/// REPL_HLPR procedures are used. For known-type assignments, dynamically
/// created evaluation procedures (generated later in the pipeline) are called.
///
/// @param line The pseudo code line number being evaluated.
/// @param triggerType The statement classification (CON/VAL/LOP/SQL/PRT/EQL).
/// @param variableName The variable being evaluated (without array element).
/// @param scope The current scope (MAIN or procedure name).
/// @param expectedValue The expected value for replEquals assertions (optional).
dcl-pr evaluateLineOfPseudoCode;
  line like(t_lineOfCode.line) const;
  triggerType like(t_triggerType) const;
  variableName like(t_variable.name) const;
  scope like(t_variable.scope) const;
  expectedValue like(t_longLineOfCode) const options(*nopass);
end-pr;

/// Determine whether a line of code is a recognisable free-format statement.
///
/// Returns *on if the line starts with a known keyword (IF, ELSE, ELSEIF,
/// WHEN, OTHER, ON-ERROR, EXEC SQL, DOW, DOU, FOR) or contains an assignment
/// operator (=). The trigger type output parameter is set accordingly.
/// Case-insensitive.
///
/// @param code The complete line of code to analyse.
/// @param triggerType Output: the detected trigger type constant.
/// @return *on if a free-format evaluation was identified.
dcl-pr freeFormatEvaluationFound ind;
  code like(t_longLineOfCode) const;
  triggerType like(t_triggerType);
end-pr;

/// Check whether a free-format line ends with a semicolon.
///
/// @param code The complete line of code.
/// @return *on if the last non-blank character is a semicolon.
dcl-pr endOfFreeFormatLineFound ind;
  code like(t_longLineOfCode) const;
end-pr;

/// Determine whether a line of code is a comment.
///
/// Checks for leading *, //, --, or /* characters.
///
/// @param code The line of code to check.
/// @return *on if the line is a comment.
dcl-pr codeIsComment ind;
  code like(t_lineOfCode.code) const;
end-pr;

/// Determine whether a line is a REPL helper call (replPrint or replEquals).
///
/// @param code The line of code to check.
/// @return *on if code starts with replPrint( or replEquals(.
dcl-pr codeIsReplHelper ind;
  code like(t_longLineOfCode) const;
end-pr;

/// Generate result evaluation helper procedures for all declared variables.
///
/// Reads through every variable stored for this session and creates
/// procedures in the generated source of the form:
///   - repl_SCOPE_VARIABLEID_single (for scalar variables)
///   - repl_SCOPE_VARIABLEID_multiple (for array variables)
///
/// For data structures, the generated procedure calls the underlying
/// standalone-variable procedures for each subfield.
dcl-pr replresultEvaluationHelpers end-pr;

// Separate a /copy or /include statement into the component parts
dcl-pr separateReferenceSource likeds(t_sourceLocation);
  code like(t_lineOfCode.code) value;
end-pr;
